# ============================================================
# HOUSE OF QUEEN BEE — .env
# Copy this file, rename it to .env and fill in your details
# NEVER share this file or upload it to GitHub!
# ============================================================

# Your website URL (use http://localhost:3000 for testing)
BASE_URL=http://localhost:3000

# ── PAYNOW (Zimbabwe) ────────────────────────────────────────
# Get from: https://www.paynow.co.zw/ > Settings > Integration
PAYNOW_INTEGRATION_ID=YOUR_PAYNOW_INTEGRATION_ID
PAYNOW_INTEGRATION_KEY=YOUR_PAYNOW_INTEGRATION_KEY

# ── STRIPE (International Cards) ─────────────────────────────
# Get from: https://dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_YOUR_STRIPE_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ── PAYPAL ───────────────────────────────────────────────────
# Get from: https://developer.paypal.com > Apps & Credentials
PAYPAL_CLIENT_ID=YOUR_PAYPAL_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_PAYPAL_CLIENT_SECRET
PAYPAL_MODE=sandbox
# Change PAYPAL_MODE to "live" when you're ready to go live

# ── SERVER ───────────────────────────────────────────────────
PORT=3000
